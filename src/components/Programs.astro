---
// Merged service cards with all details where applicable
import { programs } from "../data/programs";

const newBatches = programs.filter(p => p.newBatch);
const regularPrograms = programs.filter(p => !p.newBatch);
---

<!-- Section 1: New Batches (Featured Container) -->
{newBatches.length > 0 && (
    <div class="relative mb-16 mt-12">
        <!-- Background & Border Wrapper (Clipped) -->
        <div class="absolute inset-0 border-2 border-amber-500/40 bg-gradient-to-br from-amber-900/20 via-transparent to-amber-900/10 rounded-3xl overflow-hidden">
             <div class="absolute inset-0 shimmer-effect pointer-events-none"></div>
        </div>

        <!-- Unified Hero Banner (Not Clipped) -->
        <div class="absolute -top-5 left-1/2 -translate-x-1/2 px-8 py-2 bg-amber-500 text-black text-sm font-bold uppercase tracking-widest rounded-full shadow-[0_0_20px_rgba(245,158,11,0.6)] whitespace-nowrap z-20 flex items-center gap-2">
            <span class="animate-pulse">✨</span>
            New Batches & admissions open
            <span class="animate-pulse">✨</span>
        </div>

        <!-- Content -->
        <div class="relative z-10 p-8 lg:p-12 grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {newBatches.map((program) => (
                <div class="program-card relative group">
                    <div class="h-full glass-panel p-8 transition-all duration-500 hover:border-amber-500/50 border-amber-500/20 bg-black/40 flex flex-col">
                        <!-- Header row with icon and title -->
                        <div class="flex items-start gap-4 mb-6">
                            <div class="text-4xl shrink-0 flex items-center justify-center w-16 h-16 rounded-full bg-amber-500/10 border border-amber-500/20 group-hover:scale-110 transition-transform duration-500">
                                {program.isImage ? (
                                    <img
                                        src="/assets/images/bowling_machine_transparent.png"
                                        alt={program.title}
                                        class="w-10 h-10 object-contain"
                                        loading="lazy"
                                    />
                                ) : (
                                    program.icon
                                )}
                            </div>

                            <div class="flex-1">
                                <h3 class="text-xl font-bold text-white mb-2 tracking-wide group-hover:text-amber-400 transition-colors">{program.title}</h3>
                                <p class="text-white/70 text-sm leading-relaxed">{program.desc}</p>
                            </div>
                        </div>

                        <!-- Details -->
                        <div class="mt-auto flex flex-col gap-3 pt-6 border-t border-white/10">
                            {program.ageGroup && (
                                <div class="flex items-center gap-3">
                                    <span class="text-amber-400 text-lg">👤</span>
                                    <span class="text-white/80 text-sm font-medium">{program.ageGroup}</span>
                                </div>
                            )}
                            {program.timing && (
                                <div class="flex items-center gap-3">
                                    <span class="text-amber-400 text-lg">🕐</span>
                                    <span class="text-white/80 text-sm font-medium">{program.timing}</span>
                                </div>
                            )}
                            {program.period && (
                                <div class="flex items-center gap-3">
                                    <span class="text-amber-400 text-lg">📅</span>
                                    <span class="text-white/80 text-sm font-medium">{program.period}</span>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
)}

<style>
    .shimmer-effect {
        background: linear-gradient(
            90deg,
            transparent 0%,
            rgba(251, 191, 36, 0.05) 50%,
            transparent 100%
        );
        animation: shimmer 3s ease-in-out infinite;
    }

    @keyframes shimmer {
        0%, 100% { transform: translateX(-100%); }
        50% { transform: translateX(100%); }
    }
</style>

<!-- Section 2: Regular Programs -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {regularPrograms.map((program) => (
        <div class={`program-card ${program.featured ? 'relative' : ''}`}>
            <!-- Card - Compact for 3-col layout -->
            <div class={`h-full glass-panel p-8 transition-all duration-500 hover:border-neon/30 flex flex-col ${program.featured ? 'border-neon/20' : ''}`}>
                <!-- Featured Badge -->
                {program.featured && (
                    <div class="absolute top-6 right-6 px-3 py-1 bg-neon/15 text-neon text-[10px] uppercase tracking-widest rounded-full border border-neon/20">
                        Popular
                    </div>
                )}

                <!-- Header row with icon and title -->
                <div class="flex items-start gap-4 mb-6">
                    <!-- Icon -->
                    <div class="text-4xl shrink-0 flex items-center justify-center">
                        {program.isImage ? (
                            <img
                                src="/assets/images/bowling_machine_transparent.png"
                                alt={program.title}
                                class="w-12 h-12 object-contain"
                                loading="lazy"
                            />
                        ) : (
                            program.icon
                        )}
                    </div>

                    <div class="flex-1">
                        <!-- Title -->
                        <h3 class="text-xl font-bold text-white mb-2 tracking-wide pr-16">{program.title}</h3>

                        <!-- Description -->
                        <p class="text-white/60 text-sm leading-relaxed">{program.desc}</p>
                    </div>
                </div>

                <!-- Details -->
                <div class="mt-auto flex flex-col gap-3 pt-6 border-t border-white/10">
                    {program.ageGroup && (
                        <div class="flex items-center gap-3">
                            <span class="text-neon text-lg">👤</span>
                            <span class="text-white/70 text-sm">{program.ageGroup}</span>
                        </div>
                    )}
                    {program.timing && (
                        <div class="flex items-center gap-3">
                            <span class="text-neon text-lg">🕐</span>
                            <span class="text-white/70 text-sm">{program.timing}</span>
                        </div>
                    )}
                    {program.period && (
                        <div class="flex items-center gap-3">
                            <span class="text-neon text-lg">📅</span>
                            <span class="text-white/70 text-sm">{program.period}</span>
                        </div>
                    )}
                </div>
            </div>
        </div>
    ))}
</div>
