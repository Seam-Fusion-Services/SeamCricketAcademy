---
import academy from '../data/academy.json';
import { fetchWebsiteContent } from '../lib/seamfusion-api';

// Static defaults from academy.json
let sections = academy.about.sections;

// Override with CMS content if available
try {
    const content = await fetchWebsiteContent();
    if (content?.about) {
        const about = content.about as Record<string, unknown>;
        if (Array.isArray(about.sections) && about.sections.length > 0) {
            sections = about.sections as typeof sections;
        }
    }
} catch {
    // Silent — static data already loaded
}
---
<div class="grid md:grid-cols-2 gap-10">
    {sections.map((section, i) => (
        <div class="group relative">
            <!-- Glow effect -->
            <div class="absolute -inset-1 bg-gradient-to-r from-neon/20 to-green-500/20 rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Card -->
            <div class="relative glass-panel p-10 h-full hover:scale-[1.02] transition-all duration-500">
                <!-- Icon header -->
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 rounded-2xl bg-neon/20 flex items-center justify-center text-3xl">
                        {i === 0 ? '🎯' : '💡'}
                    </div>
                    <h3 class="text-2xl font-bold text-white group-hover:text-neon transition-colors">{section.title}</h3>
                </div>

                <!-- Content -->
                <p class="text-gray-300 text-lg leading-relaxed">{section.content}</p>

                <!-- Decorative line -->
                <div class="absolute bottom-0 left-10 right-10 h-1 bg-gradient-to-r from-transparent via-neon/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
        </div>
    ))}
</div>
