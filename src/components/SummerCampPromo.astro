---
<div class="relative w-full glass-panel rounded-3xl p-8 md:p-10 flex flex-col gap-8 overflow-hidden shadow-2xl h-full border border-neon/30 hover:border-neon/60 transition-colors duration-500">
  
  <!-- Inner subtle glows -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-neon/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3 mix-blend-screen pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-green-500/10 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/3 mix-blend-screen pointer-events-none"></div>

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 z-10">
      <div>
        <h3 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight drop-shadow-md mb-3">
          Seam <span class="text-neon drop-shadow-[0_0_20px_rgba(255,215,0,0.5)]">Summer Camp</span>
        </h3>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-white/80 text-base font-medium mt-4">
          <div class="flex items-center gap-2 bg-white/5 px-3 py-1.5 rounded-lg border border-white/5"><span class="text-neon">📅</span> March 30 – May 15</div>
          <div class="flex items-center gap-2 bg-white/5 px-3 py-1.5 rounded-lg border border-white/5"><span class="text-neon">👦</span> Age: 5-16 Years</div>
          <div class="flex items-center gap-2 bg-neon/10 px-3 py-1.5 rounded-lg border border-neon/30 text-neon font-bold"><span class="text-neon opacity-80">💰</span> Rs 10,500/-</div>
        </div>
      </div>
      
      <div class="flex-shrink-0 w-full md:w-auto self-stretch md:self-auto flex flex-col items-center md:items-end justify-center gap-4 mt-6 md:mt-0">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-green-500/40 bg-green-500/10 shadow-[0_0_15px_rgba(34,197,94,0.3)]">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-green-400 text-xs font-bold tracking-widest uppercase">
            Admissions Open
          </span>
        </div>
        <a href="#contact" class="group/btn relative inline-flex items-center justify-center w-full md:w-auto px-10 py-5 rounded-2xl border border-neon/50 bg-neon/10 text-neon text-lg font-bold tracking-wide overflow-hidden transition-all duration-300 hover:border-neon hover:shadow-[0_0_30px_rgba(255,215,0,0.4)]">
          <div class="absolute inset-0 bg-neon translate-y-[100%] group-hover/btn:translate-y-0 transition-transform duration-300"></div>
          <span class="relative z-10 group-hover/btn:text-black transition-colors duration-300 flex items-center gap-2">
            ENROLL NOW
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </span>
        </a>
      </div>
    </div>
    
    <!-- Divider -->
    <div class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent z-10 my-2"></div>
    
    <!-- Features Grid -->
    <div class="z-10">
      <p class="text-white/40 uppercase tracking-widest text-xs font-semibold mb-6 text-center md:text-left">Premium Facilities & Training</p>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        <div class="flex items-start gap-3 group/feature">
          <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-neon flex-shrink-0 border border-white/5 group-hover/feature:border-neon/30 transition-colors">🏏</div>
          <span class="text-white/80 text-sm leading-tight pt-1">Astro Turf &<br/>Bowling Machine</span>
        </div>
        <div class="flex items-start gap-3 group/feature">
          <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-neon flex-shrink-0 border border-white/5 group-hover/feature:border-neon/30 transition-colors">🔥</div>
          <span class="text-white/80 text-sm leading-tight pt-1">Custom Fitness<br/>Program</span>
        </div>
        <div class="flex items-start gap-3 group/feature">
          <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-neon flex-shrink-0 border border-white/5 group-hover/feature:border-neon/30 transition-colors">🎯</div>
          <span class="text-white/80 text-sm leading-tight pt-1">Specialised 1:1<br/>Coaching</span>
        </div>
        <div class="flex items-start gap-3 group/feature">
          <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-neon flex-shrink-0 border border-white/5 group-hover/feature:border-neon/30 transition-colors">🏆</div>
          <span class="text-white/80 text-sm leading-tight pt-1">Inter & Intra<br/>Academy Matches</span>
        </div>
        <div class="flex items-start gap-3 group/feature">
          <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-neon flex-shrink-0 border border-white/5 group-hover/feature:border-neon/30 transition-colors">👫</div>
          <span class="text-white/80 text-sm leading-tight pt-1">Boys & Girls<br/>Training</span>
        </div>
        <div class="flex items-start gap-3 group/feature">
          <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-neon flex-shrink-0 border border-white/5 group-hover/feature:border-neon/30 transition-colors">🎓</div>
          <span class="text-white/80 text-sm leading-tight pt-1">Certified Professional<br/>Coaches</span>
        </div>
      </div>
    </div>
    
  </div>
